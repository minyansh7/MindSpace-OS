---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ChartFrame from '../../components/ChartFrame.astro';
import { pages, project, data, citations } from '../../lib/canonical.ts';

export function getStaticPaths() {
  return pages.map((page) => ({ params: { slug: page.slug }, props: { page } }));
}

const { page } = Astro.props;
const goEmotions = citations.find((c) => c.id === 'goemotions')!;
const otherPages = pages.filter((p) => p.slug !== page.slug);
---
<Base
  title={`${page.title} — ${project.name}`}
  description={page.subtitle}
  ogImage={`/og/${page.slug}.png`}
  pathname={`/explore/${page.slug}/`}
>
  <Nav />

  <main id="main">
  <article class="max-w-5xl mx-auto px-5 sm:px-8 pt-12 sm:pt-20 pb-12">
    <p class="eyebrow mb-4">{`#${pages.findIndex((p) => p.slug === page.slug) + 1} · view`}</p>
    <h1 class="h-display mb-4 max-w-3xl">{page.title}</h1>
    <p class="text-lg sm:text-xl text-[var(--color-text-secondary)] max-w-2xl mb-8 leading-relaxed">
      {page.subtitle}.
    </p>

    <!-- 1 paragraph + 1 callout per design review -->
    <div class="prose-editorial mb-10">
      <p>{page.intro}</p>
    </div>

    <blockquote class="pull-quote max-w-3xl mb-12">
      "{page.callout}"
    </blockquote>
  </article>

  <!-- Chart -->
  <section class="max-w-7xl mx-auto px-5 sm:px-8 pb-12">
    <ChartFrame page={page} />
    <p class="footnote mt-4 max-w-3xl">
      Based on {data.post_count_canonical.toLocaleString()} r/meditation posts and comments,
      {data.date_range_human}. Emotion classification via GoEmotions
      ({goEmotions.authors.split(',')[0]} et al. {goEmotions.year}, trained on Reddit comments —
      see <a href="/about#methodology">methodology</a> for limitations.
    </p>
  </section>

  <!-- Continue exploring -->
  <section class="max-w-7xl mx-auto px-5 sm:px-8 py-16 border-t border-[var(--color-hairline)]">
    <p class="eyebrow mb-3">Keep exploring</p>
    <h2 class="h-section mb-8">The other three views.</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {otherPages.map((p) => (
        <a href={`/explore/${p.slug}/`} class="card block p-5 group">
          <p class="eyebrow mb-2">View</p>
          <h3 class="font-display font-semibold text-lg mb-2" style="font-family: var(--font-display);">{p.title}</h3>
          <p class="text-sm text-[var(--color-text-secondary)]">{p.subtitle}</p>
        </a>
      ))}
    </div>
  </section>
  </main>

  <Footer />
</Base>
