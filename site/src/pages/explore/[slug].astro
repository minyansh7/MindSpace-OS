---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import StaticChart from '../../components/StaticChart.astro';
import PageCard from '../../components/PageCard.astro';
import JsonLd from '../../components/JsonLd.astro';
import { pages, project, data, citations } from '../../lib/canonical.ts';

export function getStaticPaths() {
  return pages.map((page) => ({ params: { slug: page.slug }, props: { page } }));
}

const { page } = Astro.props;
const goEmotions = citations.find((c) => c.id === 'goemotions')!;
const otherPages = pages.filter((p) => p.slug !== page.slug);
---
<Base
  title={`${page.title} — ${project.name}`}
  description={page.subtitle}
  ogImage={page.social_image ?? '/og/mindspace-os-meditation-community-emotion-map-overview-social-card.svg'}
  ogImageAlt={`${project.name} ${page.title} social preview`}
  pathname={`/explore/${page.slug}/`}
>
  <JsonLd
    slot="head"
    type="CreativeWork"
    pageUrl={`${project.domain}/explore/${page.slug}/`}
    pageTitle={`${page.title} — ${project.name}`}
    pageDescription={page.subtitle}
  />
  <Nav />

  <main id="main">
  <article class="max-w-5xl mx-auto px-5 sm:px-8 pt-12 sm:pt-20 pb-12">
    <p class="eyebrow mb-4">{`#${pages.findIndex((p) => p.slug === page.slug) + 1} · view`}</p>
    <h1 class="h-display mb-4 max-w-3xl">{page.title}</h1>
    <p class="text-lg sm:text-xl text-[var(--color-text-secondary)] max-w-2xl mb-8 leading-relaxed">
      {page.subtitle}.
    </p>

    <div class="prose-editorial mb-10">
      <p>{page.intro}</p>
    </div>

    {page.callout && (
      <blockquote class="pull-quote max-w-3xl mb-12">
        "{page.callout}"
      </blockquote>
    )}
  </article>

  <section class="max-w-7xl mx-auto px-5 sm:px-8 pb-12">
    <StaticChart
      src={`${page.slug}.html`}
      height={page.desktop_height}
      mobileHeight={page.mobile_height}
      title={`${page.title} — interactive chart`}
      responsiveDesktop={page.slug === 'emotion-pulse'}
    />
    <p class="footnote mt-4 max-w-3xl">
      Based on {data.post_count_canonical.toLocaleString()} posts and comments of meditation on <a href="https://www.reddit.com/" target="_blank" rel="noopener">Reddit</a>,
      {data.date_range_human}.
      {page.footnote_variant === 'weather' && (
        <span>
          Each region is sized by the number of posts in that topic; the breakdown surfaces the top three audience pain points raised when the topic comes up, color-coded by share of the quarter's posts —
          see <a href="/about#methodology">methodology</a> for limitations.
        </span>
      )}
      {page.footnote_variant === 'currents' && (
        <span>
          Lines pair themes from busy, emotional threads (engagement &gt; 30, intensity &gt; 0.3); thicker line = more engagement —
          see <a href="/about#methodology">methodology</a> for limitations.
        </span>
      )}
      {page.footnote_variant === 'goemotions' && (
        <span>
          Emotion classification via Google Research's <a href={goEmotions.blog} target="_blank" rel="noopener">GoEmotions</a>
          ({goEmotions.authors.split(',')[0]} et al. {goEmotions.year}), trained on Reddit comments —
          see <a href="/about#methodology">methodology</a> for limitations.
        </span>
      )}
    </p>
  </section>

  <!-- Continue exploring -->
  <section class="max-w-7xl mx-auto px-5 sm:px-8 py-16 border-t border-[var(--color-hairline)]">
    <p class="eyebrow mb-3">Keep exploring</p>
    <h2 class="h-section mb-8">The other three views.</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {otherPages.map((p) => (
        <PageCard page={p} index={pages.findIndex((x) => x.slug === p.slug)} />
      ))}
    </div>
  </section>
  </main>

  <Footer />
</Base>
