---
/* StaticChart — embeds a self-hosted chart HTML file via iframe.
   No Streamlit at runtime, no cold start. The chart HTML loads Plotly.js
   from CDN, which is cached across pages after first load.

   Generated by scripts/build_chart_figures.py — re-run on data changes.

   The iframe is rendered without a `src` so the browser doesn't issue a
   first fetch on parse. A sync inline script immediately after the iframe
   reads `data-time-of-day` (set in <head> by Base.astro) and assigns
   src=base+?tod=<slot>. The script runs the moment the parser hits it —
   no DOMContentLoaded wait, no cancel-and-restart double fetch.

   Mobile: uses a smaller min-height at narrow viewports so the chart
   doesn't reserve giant whitespace before its content fills in. The
   chart HTMLs ship their own narrow-viewport CSS (see MOBILE_CSS in
   build_chart_figures.py); this component just sizes the surrounding
   iframe envelope. */

interface Props {
  /** path under /public/charts/, e.g. "emotion-pulse.html" */
  src: string;
  /** desktop iframe height in px (chart-specific to fit content without scrollbars) */
  height: number;
  /** mobile iframe height in px. Default: 70% of desktop, min 600px. */
  mobileHeight?: number;
  /** accessible title for screen readers */
  title: string;
  /**
   * If true, desktop iframe height becomes clamp(520px, 70vh, height) instead
   * of a fixed pixel value. Modern editorial-fold-fit pattern (NYT Upshot,
   * Pudding, FT). Mobile already uses clamp regardless.
   * Opt-in per chart because the Sankey, weather-report, and currents pages
   * have layout-specific tall heights tuned to fit their multi-section
   * content; shrinking those would clip content inside the iframe.
   */
  responsiveDesktop?: boolean;
}

const { src, height, mobileHeight, title, responsiveDesktop = false } = Astro.props;
/* Chart HTMLs change only when the bake script re-runs, which is part of
   the deploy. CF Pages assigns a fresh deployment URL per build, so no
   per-component cachebuster is needed — the underlying file's path is
   already stable for the lifetime of the deploy.

   Strip the .html extension: CF Pages serves chart files at the
   extension-stripped path and 308-redirects /foo.html -> /foo. Linking
   to the canonical path eliminates one round-trip per chart load
   (~600ms cold). The file on disk stays *.html for build script clarity. */
const slug = src.replace(/\.html$/, '');
const baseSrc = `/charts/${slug}`;
const mobileH = mobileHeight ?? Math.max(600, Math.round(height * 0.7));
---
<figure class="w-full static-chart" data-static-chart data-responsive-desktop={responsiveDesktop ? '' : undefined}>
  <div class="static-chart-frame w-full rounded-xl overflow-hidden border border-[var(--color-hairline)]">
    <iframe
      data-base-src={baseSrc}
      title={title}
      fetchpriority="high"
      class="static-chart-iframe w-full border-0 block"
      allowfullscreen
    ></iframe>
    <script is:inline define:vars={{ baseSrc }}>
      (function () {
        var iframe = document.currentScript.previousElementSibling;
        if (!iframe || iframe.tagName !== 'IFRAME') return;
        var tod = document.documentElement.getAttribute('data-time-of-day') || '';
        iframe.src = tod ? baseSrc + '?tod=' + encodeURIComponent(tod) : baseSrc;
      })();
    </script>
  </div>
</figure>

<style define:vars={{ desktopHeight: `${height}px`, mobileHeight: `${mobileH}px` }}>
  /* Phone heights flex with the device via clamp(min, 80vh, max) so the
     chart fits a 320px iPhone SE (667vh = 533) and a 430px iPhone Pro Max
     (932vh = 745) without a step ladder. The chart HTML's own .plot-wrap
     uses a matching clamp; iframe stays tall enough to host whichever
     end of the range applies. */
  .static-chart-frame {
    min-height: clamp(560px, 82vh, var(--mobileHeight));
  }
  .static-chart-iframe {
    height: clamp(560px, 82vh, var(--mobileHeight));
    background: transparent;
  }
  /* Desktop default: fixed height per canonical.json. Used by Sankey,
     weather-report, and currents — their multi-section layouts are
     tuned for specific pixel heights. */
  @media (min-width: 1024px) {
    .static-chart-frame { min-height: var(--desktopHeight); }
    .static-chart-iframe { height: var(--desktopHeight); }
  }
  /* Desktop with responsiveDesktop opt-in: vh-based clamp matching the
     mobile pattern. 70vh is the editorial median (NYT Upshot, Pudding,
     FT) for inline analytical charts: chart + 1-2 lines of context fit
     one viewport on any common laptop. Floor 520px keeps clusters
     legible on the smallest laptops; cap var(--desktopHeight) treats
     canonical.json's desktop_height as the upper bound on ultra-tall
     monitors. */
  @media (min-width: 1024px) {
    .static-chart[data-responsive-desktop] .static-chart-frame {
      min-height: clamp(520px, 70vh, var(--desktopHeight));
    }
    .static-chart[data-responsive-desktop] .static-chart-iframe {
      height: clamp(520px, 70vh, var(--desktopHeight));
    }
  }
</style>
