---
/* StaticChart — embeds a self-hosted chart HTML file via iframe.
   No Streamlit at runtime, no cold start. The chart HTML loads Plotly.js
   from CDN, which is cached across pages after first load.

   Generated by scripts/build_chart_figures.py — re-run on data changes.

   The iframe src is rebuilt on the client (script below) so we can append
   ?tod=<dawn|morning|afternoon|evening|night> matching the visitor's local
   time. The chart HTML reads the param and themes itself in lockstep with
   the homepage gradient. */

interface Props {
  /** path under /public/charts/, e.g. "emotion-pulse.html" */
  src: string;
  /** iframe height in px (chart-specific to fit content without scrollbars) */
  height: number;
  /** accessible title for screen readers */
  title: string;
}

const { src, height, title } = Astro.props;
// Cloudflare Pages strips `.html` and 308-redirects /foo.html → /foo. Drop the
// extension so the iframe hits the canonical URL on the first request and
// skips a ~900ms cold-start round-trip.
const baseSrc = `/charts/${src.replace(/\.html$/, '')}`;
---
<figure class="w-full" data-static-chart>
  <div
    class="w-full rounded-xl overflow-hidden border border-[var(--color-hairline)]"
    style={`min-height: ${height}px;`}
  >
    <iframe
      src={baseSrc}
      data-base-src={baseSrc}
      title={title}
      loading="eager"
      fetchpriority="high"
      class="w-full border-0 block"
      style={`height: ${height}px; background: transparent;`}
      allowfullscreen
    ></iframe>
  </div>
</figure>

<script is:inline>
  // Append visitor's local time-of-day to the iframe src so the static chart
  // HTML can theme itself in lockstep with the homepage gradient. Runs once
  // on DOMContentLoaded; no cost after that.
  document.addEventListener('DOMContentLoaded', () => {
    const tod = document.documentElement.getAttribute('data-time-of-day');
    if (!tod) return;
    document.querySelectorAll('[data-static-chart] iframe[data-base-src]').forEach((iframe) => {
      const base = iframe.getAttribute('data-base-src');
      if (!base) return;
      const sep = base.includes('?') ? '&' : '?';
      iframe.src = base + sep + 'tod=' + encodeURIComponent(tod);
    });
  });
</script>
