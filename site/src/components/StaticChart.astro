---
/* StaticChart — embeds a self-hosted chart HTML file via iframe.
   No Streamlit at runtime, no cold start. The chart HTML loads Plotly.js
   from CDN, which is cached across pages after first load.

   Generated by scripts/build_chart_figures.py — re-run on data changes.

   The iframe is rendered without a `src` so the browser doesn't issue a
   first fetch on parse. A sync inline script immediately after the iframe
   reads `data-time-of-day` (set in <head> by Base.astro) and assigns
   src=base+?tod=<slot>. The script runs the moment the parser hits it —
   no DOMContentLoaded wait, no cancel-and-restart double fetch.

   Mobile: uses a smaller min-height at narrow viewports so the chart
   doesn't reserve giant whitespace before its content fills in. The
   chart HTMLs ship their own narrow-viewport CSS (see MOBILE_CSS in
   build_chart_figures.py); this component just sizes the surrounding
   iframe envelope. */

interface Props {
  /** path under /public/charts/, e.g. "emotion-pulse.html" */
  src: string;
  /** desktop iframe height in px (chart-specific to fit content without scrollbars) */
  height: number;
  /** mobile iframe height in px. Default: 70% of desktop, min 600px. */
  mobileHeight?: number;
  /** accessible title for screen readers */
  title: string;
}

const { src, height, mobileHeight, title } = Astro.props;
/* Cachebust the iframe URL with a build-time identifier so Cloudflare Pages
   edge cache + browser cache invalidate when the chart HTML changes. Without
   this, `?tod=dawn` URL variants can serve stale chart HTML from edge cache
   even after a fresh deploy of the underlying file. Computed once per build
   at module load. */
const BUILD_ID = `b${Date.now().toString(36)}`;
const baseSrc = `/charts/${src}?v=${BUILD_ID}`;
const mobileH = mobileHeight ?? Math.max(600, Math.round(height * 0.7));
---
<figure class="w-full static-chart" data-static-chart>
  <div class="static-chart-frame w-full rounded-xl overflow-hidden border border-[var(--color-hairline)]">
    <iframe
      data-base-src={baseSrc}
      title={title}
      fetchpriority="high"
      class="static-chart-iframe w-full border-0 block"
      allowfullscreen
    ></iframe>
    <script is:inline define:vars={{ baseSrc }}>
      (function () {
        var iframe = document.currentScript.previousElementSibling;
        if (!iframe || iframe.tagName !== 'IFRAME') return;
        var tod = document.documentElement.getAttribute('data-time-of-day') || '';
        // baseSrc already has ?v=<buildId>; append tod with & if present
        var sep = baseSrc.indexOf('?') >= 0 ? '&' : '?';
        iframe.src = tod ? baseSrc + sep + 'tod=' + encodeURIComponent(tod) : baseSrc;
      })();
    </script>
  </div>
</figure>

<style define:vars={{ desktopHeight: `${height}px`, mobileHeight: `${mobileH}px` }}>
  /* Phone heights flex with the device via clamp(min, 80vh, max) so the
     chart fits a 320px iPhone SE (667vh = 533) and a 430px iPhone Pro Max
     (932vh = 745) without a step ladder. The chart HTML's own .plot-wrap
     uses a matching clamp; iframe stays tall enough to host whichever
     end of the range applies. */
  .static-chart-frame {
    min-height: clamp(560px, 82vh, var(--mobileHeight));
  }
  .static-chart-iframe {
    height: clamp(560px, 82vh, var(--mobileHeight));
    background: transparent;
  }
  @media (min-width: 1024px) {
    .static-chart-frame { min-height: var(--desktopHeight); }
    .static-chart-iframe { height: var(--desktopHeight); }
  }
</style>
