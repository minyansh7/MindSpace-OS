---
import '../styles/global.css';
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/inter/latin-600.css';
import '@fontsource/inter/latin-700.css';
import '@fontsource/source-serif-4/latin-400.css';
import '@fontsource/source-serif-4/latin-400-italic.css';
import '@fontsource/source-serif-4/latin-600.css';
import '@fontsource/jetbrains-mono/latin-400.css';
import '@fontsource/jetbrains-mono/latin-500.css';
import { project } from '../lib/canonical.ts';
import { identity } from '../data/identity';
import JsonLd from '../components/JsonLd.astro';

// Preload the two above-the-fold woff2 files (Inter 700 for H1, Inter 500
// for nav links + hero thesis). The @fontsource CSS gets inlined into the
// head bundle so the browser already knows the @font-face references after
// CSS parse, but a <link rel="preload"> in <head> kicks off the font
// fetch *during* HTML parse — typically 50-100ms earlier on cold-load.
// ?url returns the Vite-resolved hashed path (/_astro/inter-...woff2).
import inter700Url from '@fontsource/inter/files/inter-latin-700-normal.woff2?url';
import inter500Url from '@fontsource/inter/files/inter-latin-500-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  pathname?: string;
}

const {
  title = project.name + ' — ' + project.tagline,
  description = project.thesis,
  ogImage = '/og/mindspace-os-meditation-community-emotion-map-overview-social-card.svg',
  ogImageAlt = `${project.name} social preview card for ${project.tagline}`,
  pathname = '/',
} = Astro.props;

const canonicalUrl = new URL(pathname, project.domain).toString();
const ogUrl = new URL(ogImage, project.domain).toString();
const keywords = [
  project.name,
  project.alternate_name,
  'meditation data visualization',
  'emotion map',
  'reddit meditation analysis',
  'online community emotions',
  project.author,
].filter(Boolean).join(', ');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {/* Above-the-fold font preloads. Inter 700 paints H1; Inter 500 paints
        nav + hero thesis. Both are fontsource latin-only woff2 files served
        from /_astro/ with immutable cache. */}
    <link rel="preload" as="font" type="font/woff2" crossorigin href={inter700Url} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={inter500Url} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={project.author} />
    <meta name="creator" content={project.author} />
    <meta name="publisher" content={project.made_by} />
    <meta name="application-name" content={project.alternate_name ?? project.name} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={project.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    {project.twitter_handle && <meta name="twitter:site" content={project.twitter_handle} />}
    {project.twitter_handle && <meta name="twitter:creator" content={project.twitter_handle} />}
    <link rel="author" href={identity.links.resume} />

    <JsonLd type="WebSite" />
    <JsonLd type="Organization" />
    <JsonLd type="Person" />

    <slot name="head" />

    {/* Time-of-day gradient — homage to original Homepage.py.
        Sets data-time-of-day on <html> so CSS can swap the gradient.
        Runs synchronously in <head> to prevent FOUC. No flash. */}
    <script is:inline>
      (function () {
        var h = new Date().getHours();
        var slot =
          (h >= 5  && h < 8)  ? 'dawn'      :
          (h >= 8  && h < 12) ? 'morning'   :
          (h >= 12 && h < 17) ? 'afternoon' :
          (h >= 17 && h < 20) ? 'evening'   :
                                'night';
        document.documentElement.dataset.timeOfDay = slot;
      })();
    </script>
  </head>
  <body>
    <slot />
    {/* Cloudflare Web Analytics is auto-injected when this site is hosted on Cloudflare Pages.
        No script here in dev/preview — token is set in production via Pages dashboard.
        Privacy-respecting, no cookies, GDPR-compliant by default. */}
  </body>
</html>
