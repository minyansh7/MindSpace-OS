# Cloudflare Pages cache rules.
# https://developers.cloudflare.com/pages/configuration/headers/
#
# CDN-Cache-Control sets edge TTL independently from Cache-Control (which
# governs browser cache). Without it, CF Pages applies its no-cache default
# for HTML and returns cf-cache-status: DYNAMIC even when s-maxage is set.

# HTML routes — short browser cache, long edge cache, SWR fallback.
# Repeat visitors hit browser cache for 5 minutes; thereafter the CF edge
# returns cached HTML in <50ms while revalidating in the background.
/
  Cache-Control: public, max-age=300, s-maxage=86400, stale-while-revalidate=604800
  CDN-Cache-Control: public, max-age=86400

/explore/*
  Cache-Control: public, max-age=300, s-maxage=86400, stale-while-revalidate=604800
  CDN-Cache-Control: public, max-age=86400

/about/*
  Cache-Control: public, max-age=300, s-maxage=86400, stale-while-revalidate=604800
  CDN-Cache-Control: public, max-age=86400

# Static chart embeds (regenerated by scripts/build_chart_figures.py).
# Long browser cache + longer edge cache + SWR so a deploy still updates fast
# while repeat visitors get an instant load.
/charts/*
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800
  CDN-Cache-Control: public, max-age=2592000

# Astro hashed assets (filename-fingerprinted) — safe to immutable-cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000, immutable

# Hashed font files served by @fontsource — same story.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000, immutable

# OG images and screenshots — long cache, social crawlers respect this.
/og/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
  CDN-Cache-Control: public, max-age=2592000

/screenshots/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
  CDN-Cache-Control: public, max-age=2592000
