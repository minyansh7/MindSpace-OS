# Cloudflare Pages cache rules.
# https://developers.cloudflare.com/pages/configuration/headers/

# Static chart embeds (regenerated by scripts/build_chart_figures.py).
# Long browser cache + longer edge cache + SWR so a deploy still updates fast
# while repeat visitors get an instant load.
/charts/*
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800

# Astro hashed assets (filename-fingerprinted) — safe to immutable-cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Hashed font files served by @fontsource — same story.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# OG images and screenshots — long cache, social crawlers respect this.
/og/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/screenshots/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
